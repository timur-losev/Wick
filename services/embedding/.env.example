# Copy to .env to override defaults.
# python-dotenv loads .env automatically when present.

# Model
WAX_EMBED_MODEL=Qodo/Qodo-Embed-1-1.5B
WAX_EMBED_CACHE=G:\Proj\Agents1\Models
WAX_EMBED_DEVICE=cuda
WAX_EMBED_DTYPE=float16
WAX_EMBED_MAX_BATCH=32
WAX_EMBED_NORMALIZE=1

# HTTP bind
WAX_EMBED_HOST=127.0.0.1
WAX_EMBED_PORT=8088

# Elasticsearch (used only by scripts, not by the service itself)
WAX_ES_URL=http://127.0.0.1:9200
WAX_ES_BP_INDEX=wax_bp_v1
WAX_EMBED_DIM=1536
